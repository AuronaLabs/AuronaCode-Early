{
  "name": "aurona-code",
  "private": true,
  "version": "0.2.10",
  "packageManager": "pnpm@11.13.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "pnpm run typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "check": "biome ci Src",
    "smoke": "node scripts/smoke.mjs",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "preview": "vite preview --host 127.0.0.1 --port 1420",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "format": "biome format --write Src",
    "format:check": "biome ci --formatter-enabled=true --linter-enabled=false Src",
    "lint": "biome lint Src",
    "lint:fix": "biome lint --write Src"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/righteous": "^5.2.7",
    "@radix-ui/react-context-menu": "^2.3.2",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-menubar": "^1.1.19",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.2",
    "@tabler/icons-react": "^3.44.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "harmonyos-sans-sc-webfont-splitted": "^1.1.0",
    "highlight.js": "^11.9.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.9.3",
    "@types/highlight.js": "^10.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "strip-comments": "^2.0.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}

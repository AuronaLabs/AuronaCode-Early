{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-window",
  "description": "Desktop capabilities used by the main Aurona Code workbench.",
  "windows": ["main"],
  "permissions": [
    "core:app:allow-version",
    "core:path:allow-resolve-directory",
    "core:path:allow-join",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:menu:allow-new",
    "core:menu:allow-set-as-app-menu",
    "core:webview:allow-create-webview-window",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-hide",
    "core:window:allow-maximize",
    "core:window:allow-minimize",
    "core:window:allow-is-maximized",
    "core:window:allow-set-focus",
    "core:window:allow-show",
    "core:window:allow-start-dragging",
    "core:window:allow-unmaximize",
    "dialog:allow-open",
    "dialog:allow-save",
    "process:allow-restart",
    "updater:allow-check",
    "updater:allow-download-and-install",
    "fs:allow-applocaldata-meta",
    "fs:allow-applocaldata-read",
    "fs:allow-applocaldata-write",
    "fs:allow-applog-write",
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "**" }, { "path": "**/*" }, { "path": "/*" }, { "path": "*/**" }]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{ "path": "**" }, { "path": "**/*" }, { "path": "/*" }, { "path": "*/**" }]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [{ "path": "**" }, { "path": "**/*" }, { "path": "/*" }, { "path": "*/**" }]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{ "path": "**" }, { "path": "**/*" }, { "path": "/*" }, { "path": "*/**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "**" }, { "path": "**/*" }, { "path": "/*" }, { "path": "*/**" }]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [{ "path": "**" }, { "path": "**/*" }, { "path": "/*" }, { "path": "*/**" }]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [{ "path": "**" }, { "path": "**/*" }, { "path": "/*" }, { "path": "*/**" }]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [{ "path": "**" }, { "path": "**/*" }, { "path": "/*" }, { "path": "*/**" }]
    },
    {
      "identifier": "fs:allow-watch",
      "allow": [{ "path": "**" }, { "path": "**/*" }, { "path": "/*" }, { "path": "*/**" }]
    },
    "fs:allow-unwatch"
  ]
}
